# Copy to .env.local and fill in your values
# Use your live URL. Until brontetrailsoakville.com DNS points to Vercel, use the Vercel URL.
NEXT_PUBLIC_SITE_URL=https://bronte-trails-oakville.vercel.app
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Supabase — store form leads in the `bronte_trails` table
# Same project as Hawthorne / Enclave: https://cfzuypbljirmibmxpabi.supabase.co
SUPABASE_URL=https://cfzuypbljirmibmxpabi.supabase.co
# Settings → API → service_role (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: POST lead JSON to n8n / CRM after Supabase save
NEXT_PUBLIC_WEBHOOK_URL=https://your-n8n-instance/webhook/bronte-trails
REGISTRATION_WEBHOOK_URL=

# Optional: run table setup via CLI (Database → Connection string URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
